            <pubDate>Fri, 10 Jul 2026 00:00:00 +0000</pubDate>
            <sparkle:version>40</sparkle:version>
            <sparkle:shortVersionString>1.39</sparkle:shortVersionString>
            <description><![CDATA[
                <meta charset="utf-8">
                <style>
                    :root { color-scheme: light dark; }
                    body { font: 13px/1.5 -apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif; margin: 4px 2px; color: #1d1d1f; }
